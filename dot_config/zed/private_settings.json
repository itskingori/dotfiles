{
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "none"
  },
  "collaboration_panel": {
    "button": false
  },
  "git_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "file_scan_exclusions": [".git/"],
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true
    },
    "enable_feedback": false,
    "favorite_models": [
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.5",
        "enable_thinking": true,
        "effort": "medium"
      }
    ],
    "model_parameters": []
  },
  "icon_theme": "Catppuccin Frappé",
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark"
  },
  "use_system_window_tabs": true,
  "scroll_beyond_last_line": "off",
  "file_types": {
    "env": [".env"],
    "YAML": [
      "**/*.yml.j2",
      "**/*.yml.jinja",
      "**/*.yml.jinja2",
      "**/*.yaml.j2",
      "**/*.yaml.jinja",
      "**/*.yaml.jinja2"
    ]
  }
}
