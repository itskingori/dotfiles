{
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
    "copilot": {
      "enable_next_edit_suggestions": true
    }
  },
  "file_scan_exclusions": [".git/"],
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.4",
      "enable_thinking": false
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.3-codex",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "icon_theme": "Catppuccin Frappé",
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark"
  },
  "use_system_window_tabs": true,
  "scroll_beyond_last_line": "off",
  "file_types": {
    "env": [".env"],
    "YAML": [
      "**/*.yml.j2",
      "**/*.yml.jinja",
      "**/*.yml.jinja2",
      "**/*.yaml.j2",
      "**/*.yaml.jinja",
      "**/*.yaml.jinja2"
    ]
  }
}
